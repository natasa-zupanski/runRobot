{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build",
            "command": "dotnet",
            "type": "shell",
            "args": [
                "build",
                "runRobot"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Run",
            "command": "dotnet",
            "type": "shell",
            "args": [
                "run",
                "--project",
                "runRobot"
            ],
            "group": {
                "kind": "test",
                "isDefault": false
            }
        },
        {
            "label": "Run Debug",
            "command": "dotnet",
            "type": "shell",
            "args": [
                "run",
                "--project",
                "runRobot",
                "--",
                "input/cropped_pexels_video.mp4",
                "120",
                "--debug-steps"
            ],
            "group": {
                "kind": "test",
                "isDefault": true
            }
        }
    ]
}